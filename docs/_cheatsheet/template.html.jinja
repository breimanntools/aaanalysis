<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>AAanalysis Cheat Sheet · {{ m.version }}</title>
<style>{{ css|safe }}</style>
</head>
<body>

{%- macro footer(label) -%}
<div class="footer-bar"><span><b>AAanalysis</b> · {{ label }}</span>
  <span class="r"><a class="docs-link" href="https://{{ m.docs_url }}">{{ m.docs_url }}</a> · {{ m.version }} · {{ m.date }}</span></div>
{%- endmacro -%}

{%- macro family(F) -%}
<div class="sec">
  <div class="sec-h"><span>{{ F.name }}{% if F.under_construction %} <span class="uc">(to be extended)</span>{% endif %}{% if F.new %} <span class="uc new">v1.1</span>{% endif %}</span><span class="hint">{{ F.tag }}</span></div>
  <div class="sec-body">
    {% for row in F['rows'] %}
    {% set what = row[0] %}{% set sym = row[1] %}{% set _tag = row[3] if row|length > 3 else None %}
    {% set _fn = sym.split(' → ')[0] %}{% set _out = sym.split(' → ')[1:] %}
    <div class="cap-item"><span class="cw">{{ what }}{% if _tag %} <span class="rowtag">{{ _tag }}</span>{% endif %}</span><span class="cs">{{ _fn|replace('[pro]', '<span class="protag">pro</span>')|safe }}{% if _out %} → <span class="out">{{ _out|join(' → ')|replace('[pro]', '<span class="protag">pro</span>')|safe }}</span>{% endif %}</span></div>
    {% endfor %}
  </div>
</div>
{%- endmacro -%}

{%- macro recipe(R) -%}
<div class="sec">
  <div class="sec-h"><span>{{ R.cls }}</span><span class="hint">{{ R.tag }}</span></div>
  <div class="sec-body">
    <pre class="code">{{ R.code|hl }}</pre>
    {% if R.imgs %}<div class="pair-imgs" style="--ph:{{ R.h }}mm">
      {% for im in R.imgs %}<figure><img class="pair-img" src="{{ img_base }}{{ im }}.png" alt="{{ R.cls }}"><figcaption>{{ R.img_labels[loop.index0] }}</figcaption></figure>{% endfor %}
    </div>{% elif R.img %}<figure class="recipe-fig"><img class="recipe-img{{ ' big' if R.big }}{{ ' logo' if R.logo }}" src="{{ img_base }}{{ R.img }}.png" alt="{{ R.cls }} output">{% if R.caption %}<figcaption>{{ R.caption }}</figcaption>{% endif %}</figure>{% endif %}
  </div>
</div>
{%- endmacro -%}

{# a PAIR: two code boxes stacked, then both figures side-by-side in ONE row at a
   shared height G.h (mm) so the two plots are exactly the same height. #}
{%- macro recipe_pair(G) -%}
{%- set L = G.recipes[0] -%}{%- set R = G.recipes[1] -%}
<div class="sec pairsec">
  <div class="sec-h"><span>{{ L.cls }}</span><span class="hint">{{ L.tag }}</span></div>
  <div class="sec-body"><pre class="code">{{ L.code|hl }}</pre>
    <div class="pair-note">▼ figure below · left</div></div>
  <div class="sec-h"><span>{{ R.cls }}</span><span class="hint">{{ R.tag }}</span></div>
  <div class="sec-body"><pre class="code">{{ R.code|hl }}</pre>
    <div class="pair-note">▼ figure below · right</div></div>
  <div class="pair-imgs" style="--ph:{{ G.h }}mm">
    <figure><img class="pair-img" src="{{ img_base }}{{ L.img }}.png" alt="{{ L.cls }}"><figcaption>{{ L.caption if L.caption else 'left' }}</figcaption></figure>
    <figure><img class="pair-img" src="{{ img_base }}{{ R.img }}.png" alt="{{ R.cls }}"><figcaption>{{ R.caption if R.caption else 'right' }}</figcaption></figure>
  </div>
</div>
{%- endmacro -%}

{# ===================== PAGE 1 — ORIENT (blue) ===================== #}
<section class="page accent-blue cols3">
  <div class="cols">

    <div class="title-block">
      <img class="brand-logo" src="{{ logo_base }}logo.png" alt="AAanalysis">
      <div class="cs">v1.1 Cheat Sheet</div>
      <div class="tagline">{{ m.tagline }}</div>
      <div class="docs">{{ m.pip }} · <a class="docs-link" href="https://{{ m.docs_url }}">{{ m.docs_url }}</a></div>
    </div>

    <div class="intro">{{ m.intro|safe }}</div>

    <div class="sec">
      <div class="sec-h"><span>Install · Import · Load</span><span class="hint">core + [pro]</span></div>
      <div class="sec-body"><pre class="code">{{ c.install|hl }}</pre></div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>The Golden Workflow</span><span class="hint">canonical pipeline</span></div>
      <div class="sec-body">
        {% for s in c.golden_workflow %}
        <div class="wf-step"><span class="n">{{ s.n }}</span><span class="t">{{ s.title }}</span><span class="call">{{ s.call }}</span><span class="arrow">→</span><span class="o">{{ s.out }}</span></div>
        {% endfor %}
      </div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>Prediction Task Levels</span><span class="hint">task → setup</span></div>
      <div class="sec-body">
        {% for L in c.prediction_levels %}
        <div class="lvl-card">
          <div class="lh"><span class="nm">{{ L.level }} <span class="px">{{ L.prefix }}</span></span><span class="pill {{ L.strategy }}">{{ L.strategy }}</span></div>
          <div class="row"><b>unit:</b> {{ L.unit }}</div>
          <div class="row"><b>ref:</b> {{ L.reference }}</div>
        </div>
        {% endfor %}
        <div class="cap"><b>Output types:</b> {{ c.prediction_outputs }}</div>
        <div class="chips"><span class="chips-label">Groups:</span><span class="chip pos">1: positives</span><span class="chip neg">0: negatives</span><span class="chip relneg">0: reliable negatives</span><span class="chip unl">2: unlabeled</span></div>
        <div class="cap">Label 0 is a curated <b>negative</b> in labelled data, or a dPULearn-inferred <b>reliable negative</b> drawn from the unlabeled (2) pool.</div>
      </div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>Sequence Anatomy</span><span class="hint">the TMD model</span></div>
      <div class="sec-body">
        <table class="kv">{% for k,v in c.sequence_anatomy.rows %}<tr><td class="k">{{ k }}</td><td class="d">{{ v }}</td></tr>{% endfor %}</table>
        <div class="anat-track"><div class="seg jmd">JMD-N</div><div class="seg tmd">TMD</div><div class="seg jmd">JMD-C</div></div>
        <div class="anat-coords"><span>0</span><span>tmd_start</span><span>tmd_stop</span><span>len(seq)</span></div>
        <div class="cap">{{ c.sequence_anatomy.note }}</div>
      </div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>CPP Feature Concept</span><span class="hint">Part × Split × Scale</span></div>
      <div class="sec-body">
        {% for key in ['part','split','scale'] %}{% set O = c.feature_ontology[key] %}
        <div class="onto-row"><span class="h">{{ key|upper }}</span> <span class="s">{{ O.sub }}</span>
          <div class="it">{{ O['items']|join(' · ') }}</div></div>
        {% endfor %}
        {% set S = c.splits_schema %}
        <div class="splits">
          <div class="sp-row sp-seq"><span class="sp-lbl">{{ S.seq_label }}</span><span class="sp-cells">{{ S.seq }}</span></div>
          {% for name, mask in S.rows %}
          <div class="sp-row"><span class="sp-lbl">{{ name }}</span><span class="sp-cells">{{ mask }}</span></div>
          {% endfor %}
          <div class="sp-caption"><a href="{{ S.ref_url }}" target="_blank" rel="noopener">{{ S.ref_text }}</a></div>
        </div>
        <div class="onto-ex">{% for ex in c.feature_ontology.examples %}<div>{{ ex }}</div>{% endfor %}</div>
      </div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>CPP Strategies</span><span class="hint">via split_kws</span></div>
      <div class="sec-body">
        {% for k in ['compositional','positional'] %}{% set S = c.cpp_strategies[k] %}
        <div class="sub">{{ S.name }} <span class="pill {{ k }}">{{ S.maps }}</span></div>
        <div class="cap">{{ S.desc }}</div>
        <pre class="code">{{ S.code|hl }}</pre>
        {% endfor %}
        <div class="cap">{{ c.cpp_strategies.note }}</div>
      </div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>Which Module Should I Use?</span><span class="hint">intent → module</span></div>
      <div class="sec-body">
        {% for what, mod in c.which_module %}
        <div class="cap-item"><span class="cw">{{ what }}</span><span class="cs">{{ mod|replace('[pro]', '<span class="protag">pro</span>')|safe }}</span></div>
        {% endfor %}
      </div>
    </div>

    {% for F in c.capability_families %}{{ family(F) }}{% endfor %}

  </div>
  {{ footer('interpretable, sequence-based protein prediction') }}
</section>

{# ===================== PAGE 2 — CAPABILITIES (green) ===================== #}
<section class="page accent-blue cols3 wex">
  <div class="cols">

    <div class="page-banner">
      <div class="brand"><img class="banner-logo" src="{{ logo_base }}logo.png" alt="AAanalysis"> <span class="suffix">· Worked Examples</span></div>
      <div class="sub2">tutorial-style code with the figure each call produces</div>
    </div>

    {% for G in c.recipe_groups %}{% if G.recipes|length == 1 %}{{ recipe(G.recipes[0]) }}{% else %}{{ recipe_pair(G) }}{% endif %}{% endfor %}

  </div>
  {{ footer('tutorial-style worked examples') }}
</section>

{# ===================== PAGE 3 — REFERENCE (amber) ===================== #}
<section class="page accent-blue cols3">
  <div class="cols">

    <div class="page-banner">
      <div class="brand"><img class="banner-logo" src="{{ logo_base }}logo.png" alt="AAanalysis"> <span class="suffix">· Concepts &amp; Reference</span></div>
      <div class="sub2">decision guide · gotchas · options · class ↔ plot · glossary · citations</div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>Decision Guide</span><span class="hint">pick your setup</span></div>
      <div class="sec-body">
        {% for q, branches in c.decision_guide %}
        <div class="dg-q">{{ q }}</div>
        {% for label, result in branches %}
        <div class="dg-row"><span class="dg-l">{{ label }}</span> <span class="dg-r">→ {{ result }}</span></div>
        {% endfor %}
        {% endfor %}
      </div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>Gotchas</span><span class="hint">things that bite</span></div>
      <div class="sec-body"><ul class="bullets">{% for g in c.gotchas %}<li>{{ g|safe }}</li>{% endfor %}</ul></div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>Design Principles</span></div>
      <div class="sec-body"><ul class="bullets">{% for p in c.design_principles %}<li>{{ p }}</li>{% endfor %}</ul></div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>Data Objects</span><span class="hint">shapes &amp; columns</span></div>
      <div class="sec-body"><table class="kv">{% for name, cols in c.data_objects %}<tr><td class="k mono">{{ name }}</td><td class="d">{{ cols }}</td></tr>{% endfor %}</table></div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>Class · abbr ↔ Plot Class</span><span class="hint">mirrored API</span></div>
      <div class="sec-body"><table class="kv">
        <tr class="hdr"><td class="k">class</td><td class="d mono abbr">abbr</td><td class="d mono">plot class</td><td class="d" style="text-align:right">kind</td></tr>
        {% for cls,abbr,plot,kind in c.class_plot %}<tr><td class="k">{{ cls|replace('[pro]', '<span class="protag">pro</span>')|safe }}</td><td class="d mono abbr">{{ abbr }}</td><td class="d mono">{{ plot }}</td><td class="d" style="text-align:right">{{ kind|replace('[v1.1]', '<span class="rowtag">v1.1</span>')|safe }}</td></tr>{% endfor %}
      </table></div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>aa.options</span><span class="hint">system-level settings</span></div>
      <div class="sec-body"><pre class="code">{{ c.options|hl }}</pre></div>
    </div>

    <div class="sec">
      <div class="sec-h"><span>How to Cite</span><span class="hint">if you use AAanalysis</span></div>
      <div class="sec-body">{% for cit in c.citations %}
        <div class="cite-item"><span class="ky"><a href="{{ cit.url }}" target="_blank" rel="noopener">{{ cit.key }}</a></span><span class="nm">{{ cit.name }}</span>
          <div class="rf">{{ cit.ref }}</div><div class="jr"><a href="{{ cit.url }}" target="_blank" rel="noopener">{{ cit.journal }} ↗</a></div></div>
      {% endfor %}</div>
    </div>

    <div class="sec gloss-wide">
      <div class="sec-h"><span>Glossary</span><span class="hint">canonical vocabulary · CONTEXT.md</span></div>
      <div class="sec-body gloss-cols">
        {% for row in c.glossary %}{% set term = row[0] %}{% set d = row[1] %}{% set _tag = row[2] if row|length > 2 else None %}<div class="gloss-item"><b>{{ term }}</b>{% if _tag %} <span class="rowtag">{{ _tag }}</span>{% endif %} — {{ d }}</div>{% endfor %}
      </div>
    </div>

  </div>
  {{ footer('concepts & reference · decision guide · glossary') }}
</section>

</body>
</html>
