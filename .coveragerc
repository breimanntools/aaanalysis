# Coverage configuration (auto-discovered by coverage.py / pytest-cov).
#
# Kept as a standalone .coveragerc rather than a [tool.coverage] block in
# pyproject.toml so it is not a CONFIRM-FIRST surface and stays independent of
# the PEP 621 / Poetry duality in that file.

[run]
# _comp_seq_cons.py is orphan code: no __init__.py imports it, so comp_seq_cons /
# get_msa / map_known_mutations are unreachable from the public ``aa.*`` API. It
# is therefore excluded from the coverage report (it would otherwise sit at 0%
# and drag the seq_analysis_pro number down) instead of being blessed with tests
# for code no user can call. Wire it into the public API before measuring it.
omit =
    */seq_analysis_pro/_comp_seq_cons.py
